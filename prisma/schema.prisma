// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────── ENUMS ───────────────────────────

enum MarketStatus {
  PENDING
  ACTIVE
  RESOLVING
  RESOLVED
  CANCELLED
}

enum MarketCategory {
  FED
  ECB
  ELECTION
  GEOPOLITICAL
  CRYPTO
  MACRO
  SPORTS
  ENTERTAINMENT
  POLITICS
}

enum SettlementCurrency {
  USDC
  EURC
}

enum TradeDirection {
  YES
  NO
}

enum TradeStatus {
  PENDING
  EXECUTED
  FAILED
  CANCELLED
}

enum PositionStatus {
  OPEN
  CLOSED
  HEDGED
  STOP_LOSS
}

enum SubscriptionType {
  PER_TRACE
  DAILY_PASS
}

enum SubscriptionStatus {
  PENDING_PAYMENT
  ACTIVE
  EXPIRED
  CANCELLED
  FAILED
  REVOKED
  LIMIT_REACHED
}

enum AgentType {
  MARKET_MAKER
  TRADER
}

enum LogLevel {
  INFO
  WARN
  ERROR
  DEBUG
}

// ─────────────────────────── MODELS ───────────────────────────

/// Registered subscribers who pay for reasoning traces
model User {
  id            String         @id @default(uuid())
  walletAddress String         @unique
  email         String?        @unique
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  subscriptions Subscription[]
  copyTrades    CopyTrade[]
  paymentEvents PaymentEvent[]
  spendingAllowance SpendingAllowance?

  @@index([walletAddress])
  @@map("users")
}

/// AI-generated prediction markets deployed on Arc
model Market {
  id                 String             @id @default(uuid())
  question           String
  category           MarketCategory
  status             MarketStatus       @default(PENDING)
  settlementCurrency SettlementCurrency @default(USDC)
  initialYesProb     Float
  currentYesProb     Float?
  confidenceInterval Json               // { lower: Float, upper: Float }
  expiryTimestamp    DateTime
  resolutionOracle   String?
  resolvedOutcome    Boolean?
  resolvedAt         DateTime?
  minimumLiquidity   Float              @default(100)
  totalLiquidity     Float              @default(0)
  onChainAddress     String?            @unique
  txHash             String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  generationJob MarketGenerationJob? @relation("MarketGenerationJobMarket")

  trades         Trade[]
  positions      Position[]
  reasoningTraces ReasoningTrace[]
  copyTrades     CopyTrade[]
  agentLogs      AgentLog[]

  @@index([status])
  @@index([category])
  @@index([expiryTimestamp])
  @@index([settlementCurrency])
  @@index([resolvedAt])
  @@map("markets")
}

// Background job for market generation process, tracking status and errors
model MarketGenerationJob {
  id          String   @id @default(cuid())
  status      String   @default("PROCESSING")
  marketId    String?  @unique
  traceId     String?
  error       String?
  startedAt   DateTime @default(now())
  completedAt DateTime?

  market Market? @relation("MarketGenerationJobMarket", fields: [marketId], references: [id])

  @@index([status])
  @@map("market_generation_jobs")
}

/// Individual trade executed by the Trader Agent
model Trade {
  id           String         @id @default(uuid())
  marketId     String
  direction    TradeDirection
  status       TradeStatus    @default(PENDING)
  amount       Float
  price        Float
  edgeDetected Float
  kellyFraction Float
  txHash       String?
  builderFee   Float          @default(0)
  errorMessage String?
  executedAt   DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  market     Market      @relation(fields: [marketId], references: [id], onDelete: Cascade)
  position   Position?
  copyTrades CopyTrade[]

  @@index([marketId])
  @@index([status])
  @@index([createdAt])
  @@map("trades")
}

/// Tracks the open/closed lifecycle of an agent position
model Position {
  id           String         @id @default(uuid())
  marketId     String
  tradeId      String         @unique
  direction    TradeDirection
  status       PositionStatus @default(OPEN)
  entryPrice   Float
  currentPrice Float?
  size         Float
  pnl          Float          @default(0)
  hedgeMarketId String?
  closedAt     DateTime?
  closeReason  String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  market Market  @relation(fields: [marketId], references: [id], onDelete: Cascade)
  trade  Trade   @relation(fields: [tradeId], references: [id], onDelete: Cascade)

  @@index([marketId])
  @@index([status])
  @@map("positions")
}

/// Structured AI reasoning trace for every decision
model ReasoningTrace {
  id                  String    @id @default(uuid())
  marketId            String
  agentType           AgentType
  decisionType        String
  sourcesUsed         Json      // Array<{ source, weight, signal }>
  probabilityEstimate Float
  marketProbability   Float
  edge                Float
  confidenceInterval  Json      // { lower: Float, upper: Float }
  betFraction         Float?
  betSizeUsdc         Float?
  hedgeConditions     Json?     // string[]
  agentWallet         String?
  signature           String?
  ipfsCid             String?
  sha256Hash          String?
  onChainTxHash       String?
  verified            Boolean   @default(false)
  isPublic            Boolean   @default(false)
  previewSources      Json?     // First 2 sources (free preview)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  market        Market         @relation(fields: [marketId], references: [id], onDelete: Cascade)
  copyTrades    CopyTrade[]
  subscriptions Subscription[]

  @@index([marketId])
  @@index([ipfsCid])
  @@index([verified])
  @@index([createdAt])
  @@map("reasoning_traces")
}

/// A subscriber copying an agent's trade
model CopyTrade {
  id         String         @id @default(uuid())
  userId     String
  traceId    String
  marketId   String
  tradeId    String?
  direction  TradeDirection
  amount     Float
  txHash     String?
  builderFee Float          @default(0)
  status     TradeStatus    @default(PENDING)
  pnl        Float?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  user   User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  trace  ReasoningTrace @relation(fields: [traceId], references: [id], onDelete: Cascade)
  market Market         @relation(fields: [marketId], references: [id], onDelete: Cascade)
  trade  Trade?         @relation(fields: [tradeId], references: [id])

  @@index([userId])
  @@index([traceId])
  @@index([status])
  @@map("copy_trades")
}

/// Nanopayment subscription for trace access
model Subscription {
  id         String             @id @default(uuid())
  userId     String
  traceId    String?
  type       SubscriptionType
  status     SubscriptionStatus @default(ACTIVE)
  amountPaid Float
  currency   String             @default("USDC")
  txHash     String?
  expiresAt  DateTime?
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  user  User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  trace ReasoningTrace? @relation(fields: [traceId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([expiresAt])
  @@map("subscriptions")
}

/// Full audit trail of every agent decision and action
model AgentLog {
  id        String    @id @default(uuid())
  agentType AgentType
  level     LogLevel  @default(INFO)
  action    String
  marketId  String?
  data      Json?
  error     String?
  createdAt DateTime  @default(now())

  market Market? @relation(fields: [marketId], references: [id])

  @@index([agentType])
  @@index([level])
  @@index([createdAt])
  @@map("agent_logs")
}

/// Cached raw signal payloads from ingestion APIs
model SignalCache {
  id        String   @id @default(uuid())
  source    String
  payload   Json
  fetchedAt DateTime @default(now())
  expiresAt DateTime

  @@index([source])
  @@index([expiresAt])
  @@map("signal_cache")
}

/// Tracks last processed block per chain for the event indexer
model BlockIndex {
  id              String   @id @default(uuid())
  chainId         Int
  lastBlockNumber BigInt   @default(0)
  updatedAt       DateTime @updatedAt

  @@unique([chainId])
  @@map("block_index")
}

// Event emitted for every payment transaction related to subscriptions and copy trading
model PaymentEvent {
  id            String   @id @default(uuid())
  userId        String
  txHash        String   @unique
  type          String   // DAILY_PASS | PER_TRACE | REFUND
  amount        Float
  currency      String   @default("USDC")
  status        String   // PENDING | CONFIRMED | FAILED
  traceId       String?
  metadata      Json?
  createdAt     DateTime @default(now())
  confirmedAt   DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([txHash])
  @@map("payment_events")
}

// User-defined spending approvals for nanopayment trace access
model SpendingAllowance {
  id           String   @id @default(uuid())
  userId       String   @unique
  dailyLimit   Float
  perTraceLimit Float
  spentToday   Float    @default(0)
  currency     String   @default("USDC")
  lastResetAt  DateTime @default(now())
  isActive     Boolean  @default(true)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("spending_allowances")
}
